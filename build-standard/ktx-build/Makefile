# Build rule for target.
g_spawn.asm: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 g_spawn.asm
.PHONY : g_spawn.asm

# fast build rule for target.
g_spawn.asm/fast:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/g_spawn.asm.dir/build.make CMakeFiles/g_spawn.asm.dir/build
.PHONY : g_spawn.asm/fast

